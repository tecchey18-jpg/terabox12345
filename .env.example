# ============================================================
# TeraStreamBot - Environment Configuration Example
# Copy this file to .env and fill in your values
# ============================================================

# ----- TELEGRAM BOT -----
# Get this from @BotFather on Telegram after /newbot
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# Allowed user IDs (comma-separated). Leave blank to allow all users.
# Example: ALLOWED_USERS=123456789,987654321
ALLOWED_USERS=

# ----- BROWSER SETTINGS -----
# Max number of Playwright browsers running at once (RAM-sensitive!)
# Lower = safer on low-RAM VPS. Recommended: 1 or 2
MAX_CONCURRENT_BROWSERS=2

# Run browser in headless mode (true = no GUI, required on server)
PLAYWRIGHT_HEADLESS=true

# Seconds to wait for browser to extract stream URL
BROWSER_TIMEOUT=30

# ----- FILE & STORAGE -----
# Folder to store temp downloaded videos
TEMP_FOLDER=app/temp

# Auto-delete temp files after upload? (true/false)
AUTO_DELETE_FILES=true

# Max file age in minutes before forced cleanup
MAX_FILE_AGE_MINUTES=60

# ----- DOWNLOAD & UPLOAD -----
# How many seconds before download attempt times out
DOWNLOAD_TIMEOUT=300

# How many seconds before Telegram upload times out
UPLOAD_TIMEOUT=600

# Max retries for download and upload failures
MAX_RETRIES=3

# Delay in seconds between retries
RETRY_DELAY=5

# ----- VIDEO MODE -----
# Upload mode: "telegram" = send directly to Telegram chat
VIDEO_UPLOAD_MODE=telegram

# Convert m3u8 to mp4 using FFmpeg? (true/false)
CONVERT_M3U8=true

# FFmpeg output video codec (copy = no re-encoding, fastest)
FFMPEG_VIDEO_CODEC=copy

# FFmpeg output audio codec
FFMPEG_AUDIO_CODEC=aac

# ----- LOGGING -----
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log to file? (true/false)
LOG_TO_FILE=false

# Log file path (only used if LOG_TO_FILE=true)
LOG_FILE=logs/bot.log
